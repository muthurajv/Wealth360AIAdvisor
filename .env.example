# ── Azure OpenAI ──────────────────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# ── Pinecone ──────────────────────────────────────────────────────────────────
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=us-east1-gcp
PINECONE_INDEX_NAME=wealth360-poc
PINECONE_DIMENSION=1536

# ── Grafana Cloud OTLP (Traces) ───────────────────────────────────────────────
# Find these at: grafana.com → your stack → OpenTelemetry → Quickstart
GRAFANA_OTLP_ENDPOINT=https://otlp-gateway-prod-us-east-0.grafana.net/otlp
# Token = base64("<instanceId>:<apiToken>")  with role MetricsPublisher
GRAFANA_OTLP_TOKEN=your-base64-instance-token

# ── Grafana Cloud API (Dashboard deployment) ───────────────────────────────────
# Find stack URL at: grafana.com → your stack → Details
GRAFANA_CLOUD_URL=https://your-stack.grafana.net
# Service account token with role Editor
GRAFANA_API_TOKEN=your-grafana-service-account-token

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
OTEL_SERVICE_NAME=wealth360-advisor
OTEL_ENABLED=true

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=local
# Set to false when connecting real Azure OpenAI + Pinecone
USE_STUB_DATA=true
LOG_LEVEL=INFO
